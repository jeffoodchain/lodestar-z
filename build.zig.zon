.{
    .name = .state_transition_z,
    .version = "0.0.0",
    .fingerprint = 0xd1ddb6abe067ee04,
    .minimum_zig_version = "0.16.0",
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "bench",
        "bindings",
        "examples",
        "scripts",
        "src",
        "test",
    },
    .description = "Zig consensus modules for Lodestar (Ethereum beacon chain client)",
    .dependencies = .{
        .zbuild = .{
            .url = "git+https://github.com/chainsafe/zbuild.git#f7d5f19de09f2808e54acf599605f9e18c9bd804",
            .hash = "zbuild-0.4.0-XJFav-1nAgDmfVY1nVSIIzbkcbuHZj7yMb7Fv8yvznPO",
        },
        .blst = .{
            .url = "git+https://github.com/ChainSafe/blst.zig.git#5d9543be8a7a1a9942c62a097644286751f95dc7",
            .hash = "blst_zig-0.0.0-cnAxzisLAADc_A14MqXu_f_rLBRS6m6ki8zHrUjLXYoo",
            .args = .{
                .optimize = .ReleaseFast,
                .portable = true,
            },
        },
        .hashtree = .{
            .url = "git+https://github.com/ChainSafe/hashtree-z.git#81b7303f72e202e966f71eedf4be1d8d33e2fcaa",
            .hash = "hashtree-0.1.0-sBOoviYWAAA1HcTLhxWt0TtrLFXvYM5gOvxpu_Rreiiw",
        },
        .snappy = .{
            .url = "git+https://github.com/ChainSafe/snappy.zig#713942410426051da6107a955b29f3f152815622",
            .hash = "snappy-0.1.0-n4AaquQ4AADQScvw9-i6SJvZTTagvxmGgGKnat4T_a4e",
        },
        .yaml = .{
            .url = "git+https://github.com/ChainSafe/zig-yaml#b74f4e8113bee6d307c4f1fd0f190767c8196fc8",
            .hash = "zig_yaml-0.1.0-C1161kFWAwDxjKAFmklKwWVDvz2mmq0Q__bDhGGjeyd3",
        },
        .zapi = .{
            .url = "https://github.com/ChainSafe/zapi/archive/refs/tags/zapi-v2.2.0.tar.gz",
            .hash = "zapi-2.2.0-rIqzUXBaBADUsvvvB2N5kOBdLEO0rGPhowTqmIXe3qVh",
        },
        .zbench = .{
            .url = "git+https://github.com/hendriknielaender/zBench#b2b89c475e3ef1bb2bd71255c80478a82d3e0ca8",
            .hash = "zbench-0.13.0-YTdc7xVBAQCCMC-IdLLuotBeiNNNm8k9Pi2V4VYqrwfI",
        },
        .metrics = .{
            .url = "git+https://github.com/karlseguin/metrics.zig.git#6de29b83a750a06c438d268543e0e3c3c1b309da",
            .hash = "metrics-0.0.0-W7G4eIegAQD4XxA9Co7Atbw59u_2zvxYf406AZuoAHPM",
        },
        // TODO: Re-enable httpz + metrics_stf executable once karlseguin/http.zig supports Zig 0.16.0.
        // See: https://github.com/karlseguin/http.zig/issues/175
        // .httpz = .{
        //     .url = "git+https://github.com/karlseguin/http.zig.git#2924ead41db9e1986db3b4909a82185c576f6361",
        //     .hash = "httpz-0.0.0-PNVzrC7CBgDSMZNP7chgAczR3FyAz5Eum6Kb1_K9kmYR",
        // },
    },
    .options_modules = .{
        .build_options = .{
            .zero_hash_max_depth = .{
                .type = .u8,
                .description = "Maximum depth for the zero-hash table (optional; consumed as `?u8`).",
            },
            .preset = .{
                .type = .string,
                .default = "mainnet",
                .description = "Consensus preset: \"mainnet\" or \"minimal\".",
            },
        },
        .bls_options = .{
            .thread_count = .{
                .type = .u8,
                .default = 0,
                .description = "BLS thread pool size. 0 = auto (CPU count - 1).",
            },
        },
        .download_era_options = .{
            .era_base_url = .{
                .type = .string,
                .default = "https://mainnet.era.nimbus.team",
                .description = "Base URL to download ERA files from.",
            },
            .era_files = .{
                .type = .list,
                .default = .{
                    "mainnet-01628-47ac89fb.era",
                    "mainnet-01629-f4b834bc.era",
                },
                .description = "ERA files to download.",
            },
            .era_out_dir = .{
                .type = .string,
                .default = "fixtures/era",
                .description = "Local output directory for downloaded ERA files.",
            },
        },
        .spec_test_options = .{
            .spec_test_url = .{
                .type = .string,
                .default = "https://github.com/ethereum/consensus-specs",
                .description = "Git repo URL for consensus spec tests.",
            },
            .spec_test_version = .{
                .type = .string,
                .default = "v1.7.0-alpha.10",
                .description = "Consensus spec tests version tag.",
            },
            .spec_test_out_dir = .{
                .type = .string,
                .default = "test/spec/spec_tests",
                .description = "Output directory for downloaded spec tests.",
            },
        },
    },
    // Preset bundles let CI keep using `-Dpreset=mainnet` / `-Dpreset=minimal`.
    // Under new zbuild the raw flag maps to an options_module field via
    // `-Dbuild_options.preset=...`; presets wrap that so shorter CLI still works.
    .presets = .{
        .mainnet = .{
            .build_options = .{ .preset = "mainnet" },
        },
        .minimal = .{
            .build_options = .{ .preset = "minimal" },
        },
    },
    .modules = .{
        .constants = .{
            .root_source_file = "src/constants/root.zig",
        },
        .hex = .{
            .root_source_file = "src/hex.zig",
        },
        .time = .{
            .root_source_file = "src/time.zig",
        },
        .cpu_count = .{
            .root_source_file = "src/cpu_count.zig",
        },
        .testing_allocators = .{
            .root_source_file = "src/testing_allocators.zig",
        },
        .hashing = .{
            .root_source_file = "src/hashing/root.zig",
            .imports = .{ .build_options, .hex, .hashtree },
        },
        .preset = .{
            .root_source_file = "src/preset/root.zig",
            .imports = .{ .build_options, .constants },
        },
        .persistent_merkle_tree = .{
            .root_source_file = "src/persistent_merkle_tree/root.zig",
            .imports = .{ .build_options, .hex, .hashing },
        },
        .ssz = .{
            .root_source_file = "src/ssz/root.zig",
            .imports = .{ .build_options, .hex, .hashing, .persistent_merkle_tree, .testing_allocators },
        },
        .consensus_types = .{
            .root_source_file = "src/consensus_types/root.zig",
            .imports = .{ .build_options, .ssz, .constants, .preset },
        },
        .config = .{
            .root_source_file = "src/config/root.zig",
            .imports = .{ .build_options, .preset, .consensus_types, .hex, .constants },
        },
        .fork_types = .{
            .root_source_file = "src/fork_types/root.zig",
            .imports = .{ .consensus_types, .constants, .config, .persistent_merkle_tree, .preset, .ssz },
        },
        .bls = .{
            .root_source_file = "src/bls/root.zig",
            .link_libraries = .{"blst"},
        },
        .state_transition = .{
            .root_source_file = "src/state_transition/root.zig",
            .imports = .{
                .build_options,
                .ssz,
                .config,
                .consensus_types,
                .bls,
                .fork_types,
                .preset,
                .constants,
                .hex,
                .persistent_merkle_tree,
                .metrics,
                .hashing,
                .time,
            },
        },
        .era = .{
            .root_source_file = "src/era/root.zig",
            .imports = .{ .consensus_types, .config, .fork_types, .preset, .state_transition, .snappy, .persistent_merkle_tree },
        },
        .fork_choice = .{
            .root_source_file = "src/fork_choice/root.zig",
            .imports = .{ .consensus_types, .config, .preset, .state_transition, .fork_types, .hex, .constants, .metrics, .time },
        },
    },
    .executables = .{
        .download_era_files = .{
            .root_module = .{
                .root_source_file = "scripts/download_era_files.zig",
                .imports = .{.download_era_options},
            },
        },
        // TODO: Re-enable metrics_stf once karlseguin/http.zig supports Zig 0.16.0.
        // See: https://github.com/karlseguin/http.zig/issues/175
        // .metrics_stf = .{
        //     .root_module = .{
        //         .root_source_file = "examples/metrics.zig",
        //         .imports = .{
        //             .consensus_types,
        //             .fork_types,
        //             .state_transition,
        //             .download_era_options,
        //             .era,
        //             .config,
        //             .preset,
        //             .httpz,
        //         },
        //     },
        // },
        .download_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/download_spec_tests.zig",
                .imports = .{.spec_test_options},
            },
        },
        .write_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/write_spec_tests.zig",
                .imports = .{ .spec_test_options, .config, .preset, .consensus_types, .state_transition },
            },
        },
        .write_ssz_generic_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/ssz/write_generic_tests.zig",
                .imports = .{.spec_test_options},
            },
        },
        .write_ssz_static_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/ssz/write_static_tests.zig",
                .imports = .{.spec_test_options},
            },
        },
        .write_bls_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/bls/write_spec_tests.zig",
                .imports = .{.spec_test_options},
            },
        },
        .bench_ssz_attestation = .{
            .root_module = .{
                .root_source_file = "bench/ssz/attestation.zig",
                .imports = .{ .config, .consensus_types, .download_era_options, .era, .ssz, .zbench },
            },
        },
        .bench_ssz_block = .{
            .root_module = .{
                .root_source_file = "bench/ssz/block.zig",
                .imports = .{ .config, .consensus_types, .download_era_options, .era, .ssz, .zbench },
            },
        },
        .bench_ssz_state = .{
            .root_module = .{
                .root_source_file = "bench/ssz/state.zig",
                .imports = .{ .config, .consensus_types, .download_era_options, .era, .ssz, .zbench },
            },
        },
        .bench_list_chunked_leaf = .{
            .root_module = .{
                .root_source_file = "bench/ssz/list_chunked_leaf.zig",
                .imports = .{ .persistent_merkle_tree, .ssz, .zbench },
            },
        },
        .bench_merkle_gindex = .{
            .root_module = .{
                .root_source_file = "bench/ssz/gindex.zig",
                .imports = .{ .hashing, .persistent_merkle_tree, .zbench },
            },
        },
        .bench_merkle_node = .{
            .root_module = .{
                .root_source_file = "src/persistent_merkle_tree/node_bench.zig",
                .imports = .{ .hashing, .zbench },
            },
        },
        .bench_hashing = .{
            .root_module = .{
                .root_source_file = "bench/ssz/hashing.zig",
                .imports = .{ .hashing, .zbench },
            },
        },
        .bench_process_block = .{
            .root_module = .{
                .root_source_file = "bench/state_transition/process_block.zig",
                .imports = .{ .state_transition, .fork_types, .consensus_types, .config, .zbench, .persistent_merkle_tree, .download_era_options, .era, .time },
                .strip = false,
                .omit_frame_pointer = false,
            },
        },
        .bench_process_epoch = .{
            .root_module = .{
                .root_source_file = "bench/state_transition/process_epoch.zig",
                .imports = .{ .state_transition, .fork_types, .consensus_types, .config, .zbench, .persistent_merkle_tree, .download_era_options, .era, .time },
            },
        },
        .bench_fork_choice_compute_deltas = .{
            .root_module = .{
                .root_source_file = "bench/fork_choice/compute_deltas.zig",
                .imports = .{ .fork_choice, .state_transition, .config, .constants, .zbench },
            },
        },
        .bench_fork_choice_on_attestation = .{
            .root_module = .{
                .root_source_file = "bench/fork_choice/on_attestation.zig",
                .imports = .{ .fork_choice, .fork_types, .consensus_types, .state_transition, .config, .constants, .zbench },
            },
        },
        .bench_fork_choice_update_head = .{
            .root_module = .{
                .root_source_file = "bench/fork_choice/update_head.zig",
                .imports = .{ .fork_choice, .state_transition, .config, .constants, .zbench },
            },
        },
    },
    .libraries = .{
        .bindings = .{
            .root_module = .{
                .root_source_file = "bindings/napi/root.zig",
                .imports = .{
                    .bls,
                    .bls_options,
                    .cpu_count,
                    .hex,
                    .persistent_merkle_tree,
                    .ssz,
                    .consensus_types,
                    .constants,
                    .preset,
                    .config,
                    .fork_types,
                    .state_transition,
                    .hex,
                    "zapi:zapi",
                },
            },
            .linkage = .dynamic,
            .linker_allow_shlib_undefined = true,
            .dest_sub_path = "bindings.node",
        },
    },
    .tests = .{
        // Per-module unit tests (mirror the old auto-generated `test:<module>` steps).
        .constants = .{ .root_module = .constants },
        .hex = .{ .root_module = .hex },
        .cpu_count = .{ .root_module = .cpu_count },
        .hashing = .{ .root_module = .hashing },
        .preset = .{ .root_module = .preset },
        .persistent_merkle_tree = .{ .root_module = .persistent_merkle_tree },
        .ssz = .{ .root_module = .ssz },
        .consensus_types = .{ .root_module = .consensus_types },
        .config = .{ .root_module = .config },
        .fork_types = .{ .root_module = .fork_types },
        .bls = .{ .root_module = .bls },
        .state_transition = .{ .root_module = .state_transition },
        .era = .{ .root_module = .era },
        .fork_choice = .{ .root_module = .fork_choice },

        .int = .{
            .root_module = .{
                .root_source_file = "test/int/era/root.zig",
                .imports = .{
                    .config,
                    .download_era_options,
                    .era,
                },
            },
        },
        .spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/root.zig",
                .imports = .{
                    .spec_test_options,
                    .consensus_types,
                    .config,
                    .fork_types,
                    .preset,
                    .snappy,
                    .state_transition,
                    .ssz,
                    .bls,
                    .persistent_merkle_tree,
                    .hex,
                },
            },
        },
        .ssz_generic_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/ssz/generic_tests.zig",
                .imports = .{ .hex, .snappy, .persistent_merkle_tree, .ssz, .spec_test_options, .yaml },
            },
        },
        .ssz_static_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/ssz/static_tests.zig",
                .imports = .{ .hex, .snappy, .persistent_merkle_tree, .ssz, .build_options, .spec_test_options, .consensus_types, .yaml },
            },
        },
        .bls_spec_tests = .{
            .root_module = .{
                .root_source_file = "test/spec/bls/spec_tests.zig",
                .imports = .{ .bls, .hex, .yaml, .spec_test_options },
            },
        },
    },
